// =============================================================================
// Smart Hamr Rev 2 — FPGA Pin Constraints (design-specific override)
// =============================================================================
// Based on gateware/rev2/constraints/byte_hamr.lpf with FujiNet-specific
// pull modes and slew rates applied to the GPIO pins that carry
// SmartPort serial signals.
//
// Per-design overrides (matching the daughter-board GPIO assignment in
// smart_hamr_top.v):
//   GPIO_1  (debug nDEVICE_SELECT):   SLEWRATE=FAST   (clean LA edges)
//   GPIO_10 (wrdata, FPGA → ESP32):   SLEWRATE=FAST   PULLMODE=NONE
//   GPIO_12 (rddata, ESP32 → FPGA):   PULLMODE=DOWN   (matches ESP32 idle-LOW)
//   GPIO_13 (sense,  ESP32 → FPGA):   PULLMODE=UP     (defined idle when
//                                                      ESP32 not driving)
//
// All other pins identical to base byte_hamr.lpf.
// =============================================================================

FREQUENCY PORT "sig_7M" 7.16 MHz;

// =============================================================================
// System Clock (100 MHz oscillator) — declared so PnR matches the LPF;
// the design itself does not use it (Smart Hamr is single-clock 7 MHz).
// =============================================================================
LOCATE COMP "CLK_100MHz" SITE "F3";
IOBUF PORT "CLK_100MHz" IO_TYPE=LVCMOS33 PULLMODE=NONE;

// =============================================================================
// SDRAM and SPI flash pads are NOT constrained here — Smart Hamr does not
// instantiate the controllers, so leaving the pins unconstrained lets nextpnr
// drop them entirely.
// =============================================================================

// =============================================================================
// JTAG
// =============================================================================
LOCATE COMP "JTAG_TDI" SITE "R5";
IOBUF PORT "JTAG_TDI" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "JTAG_TCK" SITE "T5";
IOBUF PORT "JTAG_TCK" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "JTAG_TMS" SITE "U5";
IOBUF PORT "JTAG_TMS" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "JTAG_TDO" SITE "V4";
IOBUF PORT "JTAG_TDO" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;

// =============================================================================
// Apple II Control
// =============================================================================
LOCATE COMP "PHI1" SITE "A10";
IOBUF PORT "PHI1" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "PHI0" SITE "A11";
IOBUF PORT "PHI0" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "nI_O_SELECT" SITE "A19";
IOBUF PORT "nI_O_SELECT" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "nRES_READ" SITE "A5";
IOBUF PORT "nRES_READ" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "INT_IN" SITE "A6";
IOBUF PORT "INT_IN" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "nNMI" SITE "A7";
IOBUF PORT "nNMI" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "nRES" SITE "A8";
IOBUF PORT "nRES" IO_TYPE=LVCMOS33 OPENDRAIN=ON SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "sig_7M" SITE "A9";
IOBUF PORT "sig_7M" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "Q3" SITE "B10";
IOBUF PORT "Q3" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "uSync" SITE "B11";
IOBUF PORT "uSync" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "nDMA" SITE "B6";
IOBUF PORT "nDMA" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "nIRQ" SITE "B8";
IOBUF PORT "nIRQ" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "nINH" SITE "B9";
IOBUF PORT "nINH" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "DMA_OUT" SITE "C10";
IOBUF PORT "DMA_OUT" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "nI_O_STROBE" SITE "C11";
IOBUF PORT "nI_O_STROBE" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "DMA_IN" SITE "C6";
IOBUF PORT "DMA_IN" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "R_nW" SITE "D10";
IOBUF PORT "R_nW" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "nDEVICE_SELECT" SITE "D16";
IOBUF PORT "nDEVICE_SELECT" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "INT_OUT" SITE "D9";
IOBUF PORT "INT_OUT" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "RDY" SITE "E10";
IOBUF PORT "RDY" IO_TYPE=LVCMOS33 PULLMODE=NONE;

// =============================================================================
// Apple II Address Bus (A0-A15)
// =============================================================================
LOCATE COMP "A5" SITE "A16";
IOBUF PORT "A5" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A3" SITE "A17";
IOBUF PORT "A3" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A1" SITE "A18";
IOBUF PORT "A1" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A6" SITE "B16";
IOBUF PORT "A6" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A7" SITE "B17";
IOBUF PORT "A7" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A2" SITE "B18";
IOBUF PORT "A2" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A0" SITE "B19";
IOBUF PORT "A0" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A15" SITE "C12";
IOBUF PORT "A15" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A13" SITE "C13";
IOBUF PORT "A13" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A10" SITE "C15";
IOBUF PORT "A10" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A8" SITE "C16";
IOBUF PORT "A8" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A4" SITE "C17";
IOBUF PORT "A4" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A14" SITE "D11";
IOBUF PORT "A14" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A12" SITE "D14";
IOBUF PORT "A12" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A11" SITE "D15";
IOBUF PORT "A11" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;
LOCATE COMP "A9" SITE "E15";
IOBUF PORT "A9" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=UP;

// =============================================================================
// Apple II Data Bus (D0-D7)
// =============================================================================
LOCATE COMP "D6" SITE "A12";
IOBUF PORT "D6" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "D4" SITE "A13";
IOBUF PORT "D4" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "D2" SITE "A14";
IOBUF PORT "D2" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "D0" SITE "A15";
IOBUF PORT "D0" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "D7" SITE "B12";
IOBUF PORT "D7" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "D5" SITE "B13";
IOBUF PORT "D5" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "D1" SITE "B15";
IOBUF PORT "D1" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;
LOCATE COMP "D3" SITE "C14";
IOBUF PORT "D3" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;

// =============================================================================
// Level Shifter OE (Apple II data bus, U12)
// =============================================================================
LOCATE COMP "DATA_OE" SITE "B20";
IOBUF PORT "DATA_OE" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;

// =============================================================================
// GPIO Header (Smart Hamr / FujiNet bridge)
// =============================================================================
LOCATE COMP "GPIO_1"  SITE "P3";
IOBUF PORT "GPIO_1"  IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=FAST PULLMODE=NONE;   // /DEV debug → LA (damped pad, fine for slow probe)
LOCATE COMP "GPIO_2"  SITE "P1";
IOBUF PORT "GPIO_2"  IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // unused
LOCATE COMP "GPIO_3"  SITE "P2";
IOBUF PORT "GPIO_3"  IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // unused
LOCATE COMP "GPIO_4"  SITE "N1";
IOBUF PORT "GPIO_4"  IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // unused
LOCATE COMP "GPIO_5"  SITE "M1";
IOBUF PORT "GPIO_5"  IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // unused
LOCATE COMP "GPIO_6"  SITE "L2";
IOBUF PORT "GPIO_6"  IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // unused (damped)
LOCATE COMP "GPIO_7"  SITE "L1";
IOBUF PORT "GPIO_7"  IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // unused
LOCATE COMP "GPIO_8"  SITE "K3";
IOBUF PORT "GPIO_8"  IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // unused
LOCATE COMP "GPIO_9"  SITE "K1";
IOBUF PORT "GPIO_9"  IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // _enbl2
LOCATE COMP "GPIO_10" SITE "K2";
IOBUF PORT "GPIO_10" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=FAST PULLMODE=NONE;   // wrdata (fast slew)
LOCATE COMP "GPIO_11" SITE "J1";
IOBUF PORT "GPIO_11" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // unused (damped)
// Input (ESP32 → FPGA):
LOCATE COMP "GPIO_12" SITE "H2";
IOBUF PORT "GPIO_12" IO_TYPE=LVCMOS33 PULLMODE=DOWN;                          // rddata (idle LOW)
LOCATE COMP "GPIO_13" SITE "H1";
IOBUF PORT "GPIO_13" IO_TYPE=LVCMOS33 PULLMODE=UP;                            // sense/ACK (idle high)
// Outputs continued:
LOCATE COMP "GPIO_14" SITE "G2";
IOBUF PORT "GPIO_14" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // _wrreq
LOCATE COMP "GPIO_15" SITE "G1";
IOBUF PORT "GPIO_15" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // phase[1]
LOCATE COMP "GPIO_16" SITE "F2";
IOBUF PORT "GPIO_16" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // phase[0] (damped, OK for phase)
LOCATE COMP "GPIO_17" SITE "F1";
IOBUF PORT "GPIO_17" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // phase[3]
LOCATE COMP "GPIO_18" SITE "E2";
IOBUF PORT "GPIO_18" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // phase[2]
LOCATE COMP "GPIO_19" SITE "E1";
IOBUF PORT "GPIO_19" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // unused
LOCATE COMP "GPIO_20" SITE "D2";
IOBUF PORT "GPIO_20" IO_TYPE=LVCMOS33 DRIVE=8 SLEWRATE=SLOW PULLMODE=NONE;   // _enbl1
