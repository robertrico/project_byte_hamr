 10  HOME : PRINT "BYTE HAMR SD CARD MANAGER": PRINT "==========================": PRINT
 20  S = 49280 + 4 * 16: REM  SLOT 4 I/O BASE ($C0C0)
 25  PRINT "INITIALIZING SD CARD...";
 26  POKE S + 8,2: REM  TRIGGER SD INIT
 27  FOR W = 1 TO 2000: A =  PEEK (S + 8): IF A > 127 THEN W = 2000
 28  NEXT W
 29  PRINT
 30  A =  PEEK (S + 8): REM  SD_STATUS REG
 40  IF A < 128 THEN  PRINT "NO SD CARD DETECTED": END
 50  N =  PEEK (S + 9): REM  IMG_COUNT
 60  IF N = 0 THEN  PRINT "NO IMAGES ON SD CARD": END
 70  FOR I = 0 TO N - 1
 80  POKE S + 9,I: REM  IMG_SELECT
 90  B =  PEEK (S + 11) +  PEEK (S + 12) * 256
 100  NM$ = ""
 110  FOR J = 0 TO 10
 120  POKE S + 10,J
 130  C =  PEEK (S + 10)
 140  IF C > 32 THEN NM$ = NM$ +  CHR$ (C)
 150  NEXT J
 160  F =  PEEK (S + 13)
 170  T$ = ".PO": IF F > 0 THEN T$ = ".2MG"
 180  PRINT I + 1;") ";NM$;T$;" (";B;" BLOCKS)"
 190  NEXT I
 200  PRINT : INPUT "SELECT IMAGE (0=QUIT): ";S%
 210  IF S% = 0 THEN  END
 220  POKE S + 9,S% - 1
 230  POKE S + 8,1: REM  MOUNT_CMD
 240  PRINT "LOADING";
 250 A =  PEEK (S + 8): IF (A / 16 -  INT (A / 16)) * 16 > 7 THEN  PRINT ".";: GOTO 250
 260  PRINT : PRINT "MOUNTED AS S4,D2"
 270  PRINT "TYPE: CATALOG S4,D2"
