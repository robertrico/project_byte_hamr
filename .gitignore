# KiCad backup files
*.kicad_prl
*-backups/
_autosave-*
*~
\#*\#
.DS_Store

# KiCad lock files
*.lck

# KiCad generated files
*-cache.lib
*-rescue.lib
*.bak
*.kicad_pcb-bak
*.kicad_sch-bak
*.net

# Gerber and drill files (uncomment if you don't want to track manufacturing files)
*.gbr
*.drl
*.gbrjob

# BOM and position files
# *.csv

# PCBWay production - only track zip archives
hardware/byte_hamr/fabrication/rev*/*
!hardware/byte_hamr/fabrication/rev*/*.zip

# 3D model cache
*.3dshapes/

# FreeCAD backup files
*.FCStd1

# fp-info-cache (regenerated by KiCad)
fp-info-cache

docs/FPGA-DS-02012-2-2-ECP5-ECP5G-Family-Data-Sheet.txt

# Build outputs
build/
*.json
*.config
*.bit
*.svf

# ESP-IDF / ESP32 firmware
sdkconfig
sdkconfig.old
dependencies.lock
managed_components/

# Python
__pycache__/
*.pyc
*.pyo

# Yosys/nextpnr intermediate files
*.log
*.rpt

# Simulation artifacts (Icarus Verilog / GTKWave)
*.vvp
*.vcd
*.out

# Reporting
/reporting/*.txt
/reporting/*.json
/reporting/*.log
# Disk images — any images/ directory anywhere, plus any .po/.dsk/.hdv/.2mg file
**/images/
*.po
*.dsk
*.hdv
*.2mg

# FujiNet config (contains WiFi credentials)
gateware/**/smart_hamr/fuji/fnconfig.ini

# Logic Analyzer Captures
*.dsl
.claude/worktrees/

gateware/**/smart_hamr/fuji/

gateware/**/flash_hamr/_FileInformation.txt
